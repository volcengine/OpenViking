{
  "id": "contextengine-openviking",
  "kind": "context-engine",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["local", "remote"]
      },
      "connection": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "baseUrl": {
            "type": "string"
          },
          "timeoutMs": {
            "type": "number",
            "minimum": 1000,
            "maximum": 120000
          },
          "apiKey": {
            "type": "string"
          },
          "agentId": {
            "type": "string"
          }
        }
      },
      "retrieval": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "lastNUserMessages": {
            "type": "number",
            "minimum": 1,
            "maximum": 50
          },
          "skipGreeting": {
            "type": "boolean"
          },
          "minQueryChars": {
            "type": "number",
            "minimum": 1,
            "maximum": 200
          },
          "targetUri": {
            "type": "string"
          },
          "injectMode": {
            "type": "string",
            "enum": ["simulated_tool_result", "text"]
          },
          "scoreThreshold": {
            "type": "number"
          }
        }
      },
      "profileInjection": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "qualityGateMinScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "maxChars": {
            "type": "number",
            "minimum": 200,
            "maximum": 10000
          }
        }
      },
      "ingestion": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "writeMode": {
            "type": "string",
            "enum": ["compact_batch", "after_turn_batch"]
          },
          "maxBatchMessages": {
            "type": "number"
          }
        }
      }
    }
  }
}
