{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node __OPENVIKING_TRAE_ROOT__/scripts/session-start.mjs __OPENVIKING_CLIENT_ID__",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node __OPENVIKING_TRAE_ROOT__/scripts/auto-recall.mjs __OPENVIKING_CLIENT_ID__",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Glob|Grep|Bash|RunCommand",
        "hooks": [
          {
            "type": "command",
            "command": "node __OPENVIKING_TRAE_ROOT__/scripts/uri-guard.mjs __OPENVIKING_CLIENT_ID__",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node __OPENVIKING_TRAE_ROOT__/scripts/auto-capture.mjs __OPENVIKING_CLIENT_ID__",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
