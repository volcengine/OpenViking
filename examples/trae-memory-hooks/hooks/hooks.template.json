{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node __OPENVIKING_TRAE_ROOT__/scripts/trae-hook.mjs session-start __OPENVIKING_CLIENT_ID__",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node __OPENVIKING_TRAE_ROOT__/scripts/trae-hook.mjs user-prompt-submit __OPENVIKING_CLIENT_ID__",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node __OPENVIKING_TRAE_ROOT__/scripts/trae-hook.mjs stop __OPENVIKING_CLIENT_ID__",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
